<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText
        android:id="@+id/edtUsuarioIdCrear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="id usuario"
        android:maxLength="20"/>
    <EditText
        android:id="@+id/edtNombreUsuarioCrear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de usuario"
        android:maxLength="20"/>
    <EditText
        android:id="@+id/edtClaveUsuarioCrear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Clave usuario"
        android:maxLength="20"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <Button
        android:id="@+id/btnRegresarUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Regresar" />

    <Button
        android:id="@+id/btnGuardarUsuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Guardar"
        android:layout_marginBottom="10dp"/>

</LinearLayout>