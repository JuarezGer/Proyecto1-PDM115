<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activityCrearPaciente"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="@color/header_blue">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_hospital_cross"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hospital App"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginStart="14dp" />

        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_user_circle"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- CONTENIDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <!-- TÍTULO Y DESCRIPCIÓN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Crear Paciente"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_black"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ingresa los datos del nuevo paciente"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="20dp" />

                <!-- SEPARADOR -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/card_blue" />

            </LinearLayout>

            <!-- SECCIÓN: DOCUMENTO Y DISTRITO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Información de Identificación"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/header_blue"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtDuiCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="DUI del paciente"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtCodDistritoCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Código distrito"
                android:text="SS0101"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="20dp" />

            <!-- SECCIÓN: NOMBRE -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombres"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/header_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtPrimerNombreCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Primer nombre"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtSegundoNombreCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Segundo nombre"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="20dp" />

            <!-- SECCIÓN: APELLIDOS -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Apellidos"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/header_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtPrimerApellidoCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Primer apellido"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtSegundoApellidoCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Segundo apellido"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="20dp" />

            <!-- SECCIÓN: INFORMACIÓN PERSONAL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Información Personal"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/header_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtFechaNacimientoCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Fecha nacimiento YYYY-MM-DD"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtGeneroCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Género"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtTelefonoCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Teléfono"
                android:inputType="phone"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="28dp" />

            <!-- BOTONES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnRegresarCrear"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Regresar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/primary_dark"
                    android:backgroundTint="#E8E8E8"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnGuardarPaciente"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Guardar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/primary_dark"
                    android:backgroundTint="@color/card_blue"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- BARRA INFERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/bottom_nav"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_home"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_profile"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSalir"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_logout"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>