<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activityCrearSeguro"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="@color/header_blue">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_hospital_cross"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hospital App"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginStart="14dp" />

        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_user_circle"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- CONTENIDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <!-- TÍTULO Y DESCRIPCIÓN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Registrar Seguro"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_black"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Seleccione el paciente, aseguradora y complete los datos de cobertura."
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="20dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/card_blue" />

            </LinearLayout>

            <!-- SECCIÓN: DATOS DEL SEGURO -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="@drawable/bg_table_card">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Paciente"
                        android:textSize="14sp"
                        android:textColor="@color/text_black"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spnPacienteSeguroCrear"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:background="@drawable/bg_table_card"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aseguradora"
                        android:textSize="14sp"
                        android:textColor="@color/text_black"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <Spinner
                        android:id="@+id/spnAseguradoraSeguroCrear"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:background="@drawable/bg_table_card"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Porcentaje de cobertura"
                        android:textSize="14sp"
                        android:textColor="@color/text_black"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/edtPorcentajeCoberturaCrear"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Ejemplo: 80"
                        android:textSize="15sp"
                        android:singleLine="true"
                        android:inputType="numberDecimal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_table_card"
                        android:textColor="@color/text_black"
                        android:textColorHint="@color/text_gray"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tipo de asegurado"
                        android:textSize="14sp"
                        android:textColor="@color/text_black"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/edtTipoAseguradoCrear"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Ejemplo: Titular o Beneficiario"
                        android:textSize="15sp"
                        android:singleLine="true"
                        android:inputType="text"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_table_card"
                        android:textColor="@color/text_black"
                        android:textColorHint="@color/text_gray"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Deductible medicina"
                        android:textSize="14sp"
                        android:textColor="@color/text_black"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/edtDeductibleMedicinaCrear"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Ejemplo: 25.00"
                        android:textSize="15sp"
                        android:singleLine="true"
                        android:inputType="numberDecimal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_table_card"
                        android:textColor="@color/text_black"
                        android:textColorHint="@color/text_gray"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Deductible operación"
                        android:textSize="14sp"
                        android:textColor="@color/text_black"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/edtDeductibleOperacionCrear"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="Ejemplo: 50.00"
                        android:textSize="15sp"
                        android:singleLine="true"
                        android:inputType="numberDecimal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:background="@drawable/bg_table_card"
                        android:textColor="@color/text_black"
                        android:textColorHint="@color/text_gray"
                        android:layout_marginBottom="14dp" />

                    <Button
                        android:id="@+id/btnGuardarSeguro"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Guardar seguro"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/primary_dark"
                        android:backgroundTint="@color/card_blue"
                        android:layout_marginTop="8dp" />

                    <Button
                        android:id="@+id/btnRegresarCrearSeguro"
                        android:layout_width="150dp"
                        android:layout_height="48dp"
                        android:text="Regresar"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/primary_dark"
                        android:backgroundTint="@color/card_blue"
                        android:layout_marginTop="14dp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/bottom_nav"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_home"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_profile"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSalir"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_logout"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
