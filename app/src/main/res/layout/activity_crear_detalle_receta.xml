<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activityCrearDetalleReceta"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="@color/header_blue">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_hospital_cross"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hospital App"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginStart="14dp" />

        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_user_circle"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- CONTENIDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <!-- TÍTULO Y DESCRIPCIÓN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="28dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Crear detalle de receta"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_black"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Datos del detalle de la receta"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginBottom="20dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/card_blue" />

            </LinearLayout>

            <Spinner
                android:id="@+id/spnRecetaCrearDetalle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:spinnerMode="dropdown"
                android:backgroundTint="@color/card_blue"
                android:popupBackground="@color/background_app"
                android:layout_marginBottom="20dp" />

            <Spinner
                android:id="@+id/spnMedicamentoCrearDetalle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:spinnerMode="dropdown"
                android:backgroundTint="@color/card_blue"
                android:popupBackground="@color/background_app"
                android:layout_marginBottom="20dp" />

            <EditText
                android:id="@+id/edtCantidadDetalleCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Cantidad"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:inputType="number"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtInstruccionesDetalleCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Instrucciones"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtPrecioHistoricoDetalleCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Precio histórico"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:inputType="numberDecimal"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtSubtotalDetalleCrear"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="28dp"
                android:backgroundTint="@color/card_blue"
                android:editable="false"
                android:hint="Subtotal"
                android:inputType="numberDecimal"
                android:padding="12dp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:textSize="15sp" />

            <!-- BOTONES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnRegresarCrearDetalleReceta"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Regresar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/primary_dark"
                    android:backgroundTint="#E8E8E8"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnGuardarDetalleReceta"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Guardar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/primary_dark"
                    android:backgroundTint="@color/card_blue"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- BARRA INFERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/bottom_nav"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_home"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_profile"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSalir"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_logout"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>