<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Eliminar Paciente"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_black"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <EditText
            android:id="@+id/edtDuiEliminar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="DUI del paciente"
            android:padding="12dp"
            android:textSize="15sp"
            android:textColor="@color/text_black"
            android:textColorHint="#999999"
            android:backgroundTint="@color/card_blue"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnBuscarEliminar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Buscar paciente"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="@color/card_blue"
            android:textColor="@color/primary_dark"
            android:layout_marginBottom="20dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/text_black"
            android:alpha="0.1"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/txtPacienteEliminar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Datos del paciente..."
            android:textSize="15sp"
            android:textColor="@color/text_black"
            android:padding="16dp"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btnEliminarPaciente"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Eliminar paciente"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:backgroundTint="@color/card_blue"
            android:textColor="@color/primary_dark"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnRegresarEliminar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Regresar"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:backgroundTint="@color/card_blue"
            android:textColor="@color/primary_dark" />

    </LinearLayout>
</ScrollView>