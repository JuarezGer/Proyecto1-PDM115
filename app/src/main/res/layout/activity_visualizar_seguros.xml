<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activityVisualizarSeguros"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="@color/header_blue">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_hospital_cross"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hospital App"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginStart="14dp" />

        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_user_circle"
            android:scaleType="fitCenter" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Listado de seguros"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_black"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toca una fila para ver todos los datos"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="22dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="315dp"
            android:scrollbars="horizontal"
            android:background="@drawable/bg_table_card">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TableLayout
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:background="@color/card_blue">

                    <TableRow
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical">

                        <TextView android:layout_width="45dp" android:layout_height="match_parent" android:gravity="center" android:text="N°" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/primary_dark" />
                        <TextView android:layout_width="75dp" android:layout_height="match_parent" android:gravity="center" android:text="Póliza" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/primary_dark" />
                        <TextView android:layout_width="115dp" android:layout_height="match_parent" android:gravity="center" android:text="Paciente" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/primary_dark" />
                        <TextView android:layout_width="95dp" android:layout_height="match_parent" android:gravity="center" android:text="Aseg." android:textSize="15sp" android:textStyle="bold" android:textColor="@color/primary_dark" />
                        <TextView android:layout_width="90dp" android:layout_height="match_parent" android:gravity="center" android:text="Cobertura" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/primary_dark" />
                        <TextView android:layout_width="110dp" android:layout_height="match_parent" android:gravity="center" android:text="Tipo" android:textSize="15sp" android:textStyle="bold" android:textColor="@color/primary_dark" />
                    </TableRow>
                </TableLayout>

                <ScrollView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1">

                    <TableLayout
                        android:id="@+id/tablaSeguros"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </ScrollView>
            </LinearLayout>
        </HorizontalScrollView>

        <Button
            android:id="@+id/btnRegresarVisualizarSeguros"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:text="Regresar"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/primary_dark"
            android:backgroundTint="@color/card_blue"
            android:layout_marginTop="44dp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/bottom_nav"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_home"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_profile"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSalir"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_logout"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
