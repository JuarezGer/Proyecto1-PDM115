<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/activityLogin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="116dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="@color/header_blue">

        <ImageView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@drawable/ic_hospital_cross"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hospital App"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginStart="16dp" />

    </LinearLayout>

    <!-- CONTENIDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bienvenido a Hospital App"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_black"
                android:gravity="center"
                android:layout_marginBottom="36dp" />

            <!-- TARJETA LOGIN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp"
                android:background="@drawable/bg_login_card">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Iniciar Sesión"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_black"
                    android:layout_marginBottom="32dp" />

                <!-- INPUT EMAIL CON ICONO MEJORADO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_login"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_email"
                        android:scaleType="fitCenter"
                        android:contentDescription="Email"
                        app:tint="@color/header_blue"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/edtUsuarioLogin"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Correo electrónico"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"
                        android:textSize="16sp"
                        android:textColor="@color/text_black"
                        android:textColorHint="#B0B0B0"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical" />

                </LinearLayout>

                <!-- INPUT CONTRASEÑA CON ICONO MEJORADO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_login"
                    android:layout_marginBottom="32dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_lock"
                        android:scaleType="fitCenter"
                        android:contentDescription="Contraseña"
                        app:tint="@color/header_blue"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/edtClaveLogin"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="Contraseña"
                        android:inputType="textPassword"
                        android:singleLine="true"
                        android:textSize="16sp"
                        android:textColor="@color/text_black"
                        android:textColorHint="#B0B0B0"
                        android:background="@android:color/transparent"
                        android:gravity="center_vertical" />

                    <ImageView
                        android:id="@+id/imgTogglePassword"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_eye"
                        android:scaleType="fitCenter"
                        android:contentDescription="Mostrar contraseña"
                        app:tint="@color/header_blue"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <Button
                    android:id="@+id/btnIniciarSesion"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Iniciar Sesión"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="@color/primary_dark"
                    android:background="@drawable/bg_button_login"
                    android:backgroundTint="@color/card_blue" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>