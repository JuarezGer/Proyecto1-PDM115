<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activityModificarEstablecimiento"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="@color/header_blue">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_hospital_cross"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hospital App"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginStart="14dp" />

        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_user_circle"
            android:scaleType="fitCenter" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modificar Establecimiento"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_black"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Busca el establecimiento por ID y modifica sus datos"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/card_blue" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Búsqueda"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/header_blue"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtIdEstablecimientoModificar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="ID del establecimiento"
                android:inputType="number"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnBuscarEstablecimientoModificar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Buscar"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/primary_dark"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Datos a modificar"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/header_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtNombreEstablecimientoModificar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Nombre del establecimiento"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtTelefonoEstablecimientoModificar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Teléfono"
                android:inputType="phone"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/edtDireccionEstablecimientoModificar"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:hint="Dirección"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:textColorHint="#999999"
                android:backgroundTint="@color/card_blue"
                android:layout_marginBottom="28dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btnRegresarModificarEstablecimiento"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Regresar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/primary_dark"
                    android:backgroundTint="#E8E8E8"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnModificarEstablecimiento"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Actualizar"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="@color/primary_dark"
                    android:backgroundTint="@color/card_blue"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/bottom_nav"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_home"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_profile"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSalir"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_logout"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
