<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activityVisualizarDetalleReceta"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:background="@color/header_blue">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalle de Receta"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"/>
    </LinearLayout>

    <!-- TABLA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <TableLayout
            android:id="@+id/tablaDetalles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="*">

            <!-- ENCABEZADO -->
            <TableRow>

                <TextView
                    android:text="N°"
                    android:textStyle="bold"/>

                <TextView
                    android:text="Medicamento"
                    android:textStyle="bold"/>

                <TextView
                    android:text="Cant"
                    android:textStyle="bold"/>

                <TextView
                    android:text="Subtotal"
                    android:textStyle="bold"/>

            </TableRow>

        </TableLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TableLayout
                android:id="@+id/tablaDetallesData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </ScrollView>

    </LinearLayout>

    <Button
        android:id="@+id/btnRegresarVisualizar"
        android:layout_width="150dp"
        android:layout_height="48dp"
        android:text="Regresar"
        android:layout_gravity="center"
        android:layout_margin="10dp"/>
</LinearLayout>