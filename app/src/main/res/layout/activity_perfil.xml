<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/activityPerfil"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="108dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:background="@color/header_blue">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_hospital_cross"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hospital App"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginStart="14dp" />

        <ImageView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_user_circle"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- CONTENIDO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Perfil de usuario"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_black"
            android:layout_marginBottom="28dp" />

        <!-- TARJETA DE PERFIL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_profile_card"
            android:padding="24dp">

            <TextView
                android:id="@+id/txtNombrePerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre del usuario"
                android:textSize="21sp"
                android:textStyle="bold"
                android:textColor="@color/text_black"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtIdUsuarioPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ID Usuario"
                android:textSize="16sp"
                android:textColor="@color/text_gray"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Información de la cuenta"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/txtInfoPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sesión activa"
                android:textSize="15sp"
                android:textColor="@color/text_black"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnCerrarSesionPerfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cerrar sesión"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:backgroundTint="@color/card_blue" />

        </LinearLayout>

    </LinearLayout>

    <!-- BARRA INFERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/bottom_nav"
        android:elevation="8dp">

        <!-- INICIO -->
        <LinearLayout
            android:id="@+id/navInicio"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_home"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <!-- PERFIL -->
        <LinearLayout
            android:id="@+id/navPerfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_profile"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perfil"
                android:textSize="13sp"
                android:textColor="@color/primary_dark"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- SALIR -->
        <LinearLayout
            android:id="@+id/navSalir"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_logout"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salir"
                android:textSize="13sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>