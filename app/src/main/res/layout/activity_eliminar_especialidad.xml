<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText
        android:id="@+id/edtIdEspecialidadEliminar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="ID Especialidad"
        android:inputType="number"/>

    <Button
        android:id="@+id/btnBuscarEspecialidadEliminar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buscar"/>

    <TextView
        android:id="@+id/txtEspecialidadEliminar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Datos de especialidad..."
        android:textSize="16sp"
        android:padding="20dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/btnEliminarEspecialidad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Eliminar"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnRegresarEliminarEspecialidad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Regresar"/>

</LinearLayout>